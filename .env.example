# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Railway provides this automatically — copy from your Railway project dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random string — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string